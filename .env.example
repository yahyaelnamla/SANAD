# SANAD Platform — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# Application
APP_NAME=SANAD
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API
API_PREFIX=/api/v1
# Dev (port 3000) and prod via Nginx (port 80)
CORS_ORIGINS=["http://localhost","http://localhost:3000"]

# Database
POSTGRES_USER=sanad
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=sanad

# Host-side URLs (local pytest / alembic outside Docker)
# URL-encode special characters in the password (! = %21, @ = %40)
DATABASE_URL=postgresql+asyncpg://sanad:change-me-strong-password@localhost:5433/sanad
TEST_DATABASE_URL=postgresql+asyncpg://sanad:change-me-strong-password@localhost:5433/sanad_test

# Redis
REDIS_URL=redis://localhost:6379/0

# Fanar AI Models (https://api.fanar.qa/v1)
FANAR_API_KEY=
FANAR_API_BASE_URL=https://api.fanar.qa/v1
FANAR_ORGANIZATION=QCRI-Hackathon
FANAR_GUARD_MIN_SAFETY=0.7
FANAR_GUARD_MIN_CULTURAL=0.7
# Multi-agent planner (Fanar-Sadiq-Agentic) — enabled by default for hackathon demo
SKIP_AGENTIC_PLANNER=false

# Pipeline tuning (optional)
MAX_EVIDENCE_TOKENS=12000
REASONING_MAX_TOKENS_FAST=8000
REASONING_MAX_TOKENS_STANDARD=16000
REASONING_MAX_TOKENS_DEEP=32000
ENABLE_CROSS_LANGUAGE_RETRIEVAL=false
SKIP_RESPONSE_SUMMARY_LLM=true

# JWT
JWT_SECRET=change-me-generate-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Market data (company scanner, zakat live prices)
ALPHA_VANTAGE_API_KEY=
MASSIVE_API_KEY=

# Web search (optional retrieval enrichment)
SERPER_API_KEY=
TAVILY_API_KEY=
LANGSEARCH_API_KEY=

# Neo4j knowledge graph (optional — local or Aura)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Platform integration API (optional — for external partners)
PLATFORM_API_KEY=

# SSO — demo mode works without OAuth credentials (hackathon / dev)
SSO_DEMO_MODE=true
SSO_REDIRECT_URI=http://localhost:3000/auth/sso/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Frontend — leave empty in production (same-origin /api via Nginx)
NEXT_PUBLIC_API_URL=http://localhost:8000
NGINX_PORT=80
